---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}
const {
  title = "JAI — Digital Product Studio",
  description = "JAI is a product and development agency that designs, builds, and ships high-performing digital experiences for ambitious brands.",
  image = "/og-image.png",
  canonical = "https://jai.studio",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="JAI" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/hand-logo.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Blue ambient glows -->
    <div class="glow glow-1" aria-hidden="true"></div>
    <div class="glow glow-2" aria-hidden="true"></div>
    <div class="glow glow-3" aria-hidden="true"></div>
    <div class="glow glow-4" aria-hidden="true"></div>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: #050505;
    --text-primary: #fcfcfc;
    --text-secondary: #bababa;
    --text-muted: #969696;
    --border-subtle: rgba(255, 255, 255, 0.2);
    --border-faint: rgba(255, 255, 255, 0.25);
    --content-width: 1200px;
    --gutter: 40px;
    --font-orbitron: "Orbitron", sans-serif;
    --font-inter: "Inter", sans-serif;
  }

  html {
    background: var(--bg);
    color: var(--text-primary);
    font-family: var(--font-orbitron);
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  body {
    background: var(--bg);
    overflow-x: hidden;
    width: 100%;
    min-height: 100vh;
  }

  main {
    width: 100%;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .container {
    width: 100%;
    max-width: var(--content-width);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  .section-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    color: var(--text-muted);
    font-size: 18px;
    letter-spacing: 7.2px;
    text-transform: uppercase;
  }

  .section-label-nocenter {
    justify-content: flex-start;
  }

  .section-label .dot {
    width: 10px;
    height: 10px;
    border-radius: 100px;
    background: white;
    flex-shrink: 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 12px 18px;
    border-radius: 60px;
    border: 1px solid var(--border-faint);
    background: transparent;
    color: var(--text-primary);
    font-family: var(--font-orbitron);
    font-size: 16px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    white-space: nowrap;
    transition:
      border-color 0.3s,
      color 0.3s;
  }

  /* shimmer sweep on hover */
  .btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(255, 255, 255, 0.08) 50%,
      transparent 60%
    );
    transform: translateX(-100%);
    transition: transform 0.55s ease;
    pointer-events: none;
  }

  .btn:hover::before {
    transform: translateX(100%);
  }

  .btn:hover {
    border-color: rgba(255, 255, 255, 0.55);
  }

  .btn .btn-icon {
    width: 31px;
    height: 31px;
    background: white;
    border-radius: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .btn:hover .btn-icon {
    transform: rotate(45deg) scale(1.1);
  }

  .btn .btn-icon svg {
    width: 14px;
    height: 14px;
    fill: black;
  }

  .divider {
    width: 100%;
    height: 1px;
    background: var(--border-faint);
  }

  /* ── Decorative button with bracket-arrows on both sides ── */
  .btn-bracketed {
    display: inline-flex;
    align-items: center;
    gap: 20px;
  }

  .btn-bracketed .bracket {
    display: flex;
    align-items: center;
    gap: 2px;
    opacity: 0.45;
  }

  .btn-bracketed .bracket svg {
    width: 90px;
    height: 90px;
  }

  .btn-bracketed .bracket.right {
    /* no flip needed — arrows already drawn pointing left */
  }

  /* ── Blue ambient glows ── */
  .glow {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    filter: blur(120px);
    opacity: 0.18;
  }

  .glow-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, #1a6fff 0%, transparent 70%);
    top: 5vh;
    left: -10vw;
  }

  .glow-2 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, #3b0fd4 0%, transparent 70%);
    top: 35vh;
    right: -8vw;
    opacity: 0.14;
  }

  .glow-3 {
    width: 700px;
    height: 400px;
    background: radial-gradient(ellipse, #0050ff 0%, transparent 65%);
    top: 65vh;
    left: 20vw;
    opacity: 0.1;
  }

  .glow-4 {
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, #2563ff 0%, transparent 70%);
    bottom: 10vh;
    right: 5vw;
    opacity: 0.12;
  }

  @media (max-width: 1024px) {
    :root {
      --gutter: 24px;
    }

    .section-label,
    .section-label-nocenter {
      font-size: 14px;
      letter-spacing: 3.6px;
      gap: 8px;
    }

    .btn {
      font-size: 14px;
      padding: 10px 16px;
      gap: 10px;
    }

    .btn .btn-icon {
      width: 28px;
      height: 28px;
    }
  }

  @media (max-width: 768px) {
    :root {
      --gutter: 16px;
    }

    html,
    body {
      max-width: 100%;
    }

    .btn-bracketed .bracket {
      display: none;
    }

    .glow {
      filter: blur(90px);
      opacity: 0.14;
    }

    .glow-1,
    .glow-2,
    .glow-3,
    .glow-4 {
      width: 300px;
      height: 300px;
    }
  }

  /* glows scroll with page on mobile, fixed on desktop */
  @media (max-width: 768px) {
    .glow {
      position: absolute;
    }
  }
</style>

<script>
  import { initAnimations } from "@/scripts/animations";
  initAnimations();
</script>
