---
import { type Locale, withLocale } from "@/i18n/config";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const copy = {
  en: {
    label: "IMPACT",
    heading:
      "Measurable results for brands that need more than a pretty interface.",
    cta: "LET'S TALK",
    stats: [
      {
        value: "40+",
        label: "Products shipped",
        desc: "From brand refreshes to full-stack launches across industries.",
      },
      {
        value: "12",
        label: "Specialists on demand",
        desc: "Designers, developers, and strategists working as one team.",
      },
      {
        value: "99%",
        label: "Client retention",
        desc: "Long-term partnerships built on clarity, speed, and outcomes.",
      },
    ],
  },
  es: {
    label: "IMPACTO",
    heading:
      "Resultados medibles para marcas que necesitan mas que una interfaz atractiva.",
    cta: "HABLEMOS",
    stats: [
      {
        value: "40+",
        label: "Productos lanzados",
        desc: "Desde refresh de marca hasta lanzamientos full-stack en distintas industrias.",
      },
      {
        value: "12",
        label: "Especialistas bajo demanda",
        desc: "Disenadores, developers y estrategas trabajando como un solo equipo.",
      },
      {
        value: "99%",
        label: "Retencion de clientes",
        desc: "Relaciones de largo plazo construidas con claridad, velocidad y resultados.",
      },
    ],
  },
} as const;

const t = copy[lang];
---

<section class="stats">
  <div class="container stats-inner">
    <div class="stats-top">
      <div class="section-label" data-reveal="left">
        <span class="dot"></span>
        <span>{t.label}</span>
      </div>
      <h2 class="stats-heading" data-reveal="up" data-delay="150">
        {t.heading}
      </h2>
    </div>

    <div class="stats-grid">
      {
        t.stats.map((stat, i) => (
          <div class="stat-card" data-reveal="up" data-delay={i * 120}>
            <div class="stat-top">
              <span class="stat-value">{stat.value}</span>
              <div class="divider" />
            </div>
            <div class="stat-bottom">
              <p class="stat-label">{stat.label}</p>
              <p class="stat-desc">{stat.desc}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="stats-cta" data-reveal="scale">
      <a href={withLocale(lang, "/blog")} class="btn">
        <span>{t.cta}</span>
        <span class="btn-icon">
          <svg viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M2 7h10M8 3l4 4-4 4"
              stroke="black"
              stroke-width="1.5"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .stats {
    padding-block: 80px;
  }

  .stats-inner {
    display: flex;
    flex-direction: column;
    gap: 72px;
  }

  .stats-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 40px;
  }

  .stats-heading {
    font-family: var(--font-orbitron);
    font-weight: 400;
    font-size: 48px;
    line-height: 1.38;
    color: white;
    max-width: 660px;
    flex: 1;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 15px;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .stat-top {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .stat-value {
    font-family: var(--font-orbitron);
    font-weight: 400;
    font-size: 68px;
    line-height: 72px;
    color: white;
    text-align: center;
    display: block;
  }

  .stat-bottom {
    display: flex;
    flex-direction: column;
    gap: 11px;
  }

  .stat-label {
    font-family: var(--font-orbitron);
    font-weight: 500;
    font-size: 22px;
    line-height: 1.7;
    color: white;
    letter-spacing: -0.48px;
  }

  .stat-desc {
    font-family: var(--font-orbitron);
    font-weight: 400;
    font-size: 19px;
    line-height: 1.6;
    color: white;
  }

  .stats-cta {
    display: flex;
    justify-content: center;
  }

  @media (max-width: 1024px) {
    .stats {
      padding-block: 64px;
    }

    .stats-inner {
      gap: 56px;
    }

    .stats-top {
      flex-direction: column;
      gap: 20px;
    }

    .stats-heading {
      font-size: 38px;
      max-width: 100%;
    }

    .stat-value {
      font-size: 56px;
      line-height: 1;
    }

    .stat-label {
      font-size: 20px;
      line-height: 1.4;
    }

    .stat-desc {
      font-size: 16px;
      line-height: 1.55;
    }
  }

  @media (max-width: 768px) {
    .stats {
      padding-block: 48px;
    }

    .stats-inner {
      gap: 40px;
    }

    .stats-heading {
      font-size: 30px;
      line-height: 1.3;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .stat-card {
      gap: 18px;
    }

    .stat-top {
      gap: 16px;
    }

    .stat-value {
      font-size: 46px;
    }

    .stat-label {
      font-size: 18px;
    }

    .stat-desc {
      font-size: 15px;
    }
  }
</style>
