---
const teamPhotos = ["agus.webp", "tofi.webp", "agus.webp", "tofi.webp"];
---

<section class="team">
  <div class="container team-inner">
    <div class="team-label">
      <div class="section-label">
        <span class="dot"></span>
        <span>THE STUDIO</span>
      </div>
    </div>

    <p class="team-bio">
      We are a small, senior team built to move quickly without sacrificing
      quality. Strategy, design, and engineering sit at the same table from day
      one.
    </p>
  </div>

  <div class="team-strip-wrap">
    <div class="team-strip">
      {
        teamPhotos.map((photo, i) => (
          <div class="team-photo">
            <img src={photo} alt={`Team member ${i + 1}`} />
          </div>
        ))
      }
    </div>
    <div class="team-overlay">
      <h2 class="team-title">Meet the Studio</h2>
      <a href="#" class="btn team-cta">
        <span>ABOUT US</span>
        <span class="btn-icon">
          <svg viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M2 7h10M8 3l4 4-4 4"
              stroke="black"
              stroke-width="1.5"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .team {
    padding-block: 80px;
  }

  .team-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 60px;
    margin-bottom: 48px;
  }

  .team-bio {
    font-family: var(--font-orbitron);
    font-weight: 400;
    font-size: 28px;
    line-height: 1.5;
    color: white;
    max-width: 600px;
  }

  .team-strip-wrap {
    position: relative;
    overflow: hidden;
  }

  .team-strip {
    display: flex;
    gap: 0;
  }

  .team-photo {
    flex-shrink: 0;
    width: calc(25%);
    overflow: hidden;
  }

  .team-photo img {
    width: 100%;
    height: 480px;
    object-fit: cover;
    display: block;
  }

  .team-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 24px;
    background: rgba(0, 0, 0, 0.35);
  }

  .team-title {
    font-family: var(--font-orbitron);
    font-weight: 600;
    font-size: 80px;
    color: white;
    letter-spacing: -2px;
  }

  .team-cta {
    font-size: 14px;
  }

  @media (max-width: 1024px) {
    .team {
      padding-block: 64px;
    }

    .team-inner {
      flex-direction: column;
      gap: 24px;
      margin-bottom: 36px;
    }

    .team-bio {
      font-size: 22px;
      max-width: 100%;
    }

    .team-strip {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
    }

    .team-photo {
      width: 100%;
    }

    .team-photo img {
      height: 360px;
    }

    .team-title {
      font-size: 62px;
      text-align: center;
    }
  }

  @media (max-width: 768px) {
    .team {
      padding-block: 48px;
    }

    .team-bio {
      font-size: 18px;
      line-height: 1.5;
    }

    .team-strip {
      grid-template-columns: 1fr;
    }

    .team-photo img {
      height: 300px;
    }

    .team-overlay {
      gap: 16px;
      padding-inline: 16px;
    }

    .team-title {
      font-size: 40px;
      letter-spacing: -1px;
    }

    .team-cta {
      font-size: 12px;
    }
  }
</style>
