---
import Layout from "@/layouts/Layout.astro";
import BlogCard from "@/components/blog/BlogCard.astro";
import { getPublishedPostsByLocale } from "@/lib/blog";

const posts = await getPublishedPostsByLocale("en");
---

<Layout
  lang="en"
  title="JAI Blog | Product, Design, and Engineering Insights"
  description="Articles from JAI Studio on digital product strategy, design systems, engineering and launch execution."
>
  <main class="blog-page container">
    <header class="blog-header" data-reveal="up">
      <p class="eyebrow">JAI Journal</p>
      <h1>Blog</h1>
      <p class="intro">
        Notes from the studio about product strategy, engineering execution, and
        systems that scale with clarity.
      </p>
    </header>

    <section class="blog-grid">
      {posts.map((post) => <BlogCard post={post} lang="en" />)}
    </section>
  </main>
</Layout>

<style>
  .blog-page {
    padding-top: 140px;
    padding-bottom: 70px;
  }

  .blog-header {
    margin-bottom: 32px;
  }

  .eyebrow {
    font-family: var(--font-orbitron);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 12px;
    margin-bottom: 12px;
  }

  h1 {
    font-family: var(--font-orbitron);
    font-size: clamp(42px, 7vw, 96px);
    line-height: 0.95;
    margin-bottom: 12px;
  }

  .intro {
    max-width: 700px;
    color: var(--text-secondary);
    font-family: var(--font-orbitron);
    line-height: 1.6;
    font-size: 17px;
  }

  .blog-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  @media (max-width: 768px) {
    .blog-page {
      padding-top: 108px;
      padding-bottom: 48px;
    }

    .intro {
      font-size: 15px;
    }

    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
