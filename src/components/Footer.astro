---
import { type Locale, withLocale } from "@/i18n/config";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const copy = {
  en: {
    bio: "Digital product studio building websites, apps, and platforms for ambitious teams.",
    credit:
      "A product and development agency focused on strategy, design, and launch.",
    col1: [
      { label: "About", href: withLocale(lang, "/#home") },
      { label: "Services", href: withLocale(lang, "/#services") },
      { label: "Work", href: withLocale(lang, "/#work") },
    ],
    col2: [
      { label: "Contact", href: "mailto:hello@jai.studio" },
      { label: "Process", href: withLocale(lang, "/#process") },
      { label: "Blog", href: withLocale(lang, "/blog") },
    ],
  },
  es: {
    bio: "Estudio de producto digital que construye sitios, apps y plataformas para equipos ambiciosos.",
    credit:
      "Una agencia de producto y desarrollo enfocada en estrategia, diseno y lanzamiento.",
    col1: [
      { label: "Nosotros", href: withLocale(lang, "/#home") },
      { label: "Servicios", href: withLocale(lang, "/#services") },
      { label: "Proyectos", href: withLocale(lang, "/#work") },
    ],
    col2: [
      { label: "Contacto", href: "mailto:hello@jai.studio" },
      { label: "Proceso", href: withLocale(lang, "/#process") },
      { label: "Blog", href: withLocale(lang, "/blog") },
    ],
  },
} as const;

const social = [
  { label: "X (Twitter)", href: "https://x.com" },
  { label: "Instagram", href: "https://instagram.com" },
  { label: "LinkedIn", href: "https://linkedin.com" },
];

const t = copy[lang];
---

<footer class="footer">
  <!-- decorative blue glow replaces figma blur asset -->
  <div class="footer-blur" aria-hidden="true"></div>

  <div class="container footer-inner">
    <div class="footer-nav">
      <div class="footer-bio" data-reveal="left">
        <p class="footer-bio-text">
          {t.bio}
        </p>
        <p class="footer-logo">JAI Studio</p>
      </div>

      <div class="footer-links" data-reveal="right" data-delay="150">
        <ul>
          {
            t.col1.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
        <ul>
          {
            t.col2.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
        <ul>
          {
            social.map((link) => (
              <li>
                <a href={link.href} target="_blank" rel="noopener noreferrer">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="footer-bar">
      <p class="footer-credit">
        {t.credit}
      </p>
    </div>

    <div class="footer-border" aria-hidden="true"></div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    padding-block: 100px 0;
    overflow: hidden;
  }

  .footer-blur {
    position: absolute;
    bottom: -100px;
    left: -100px;
    width: 800px;
    height: 300px;
    background: linear-gradient(
      135deg,
      #1a3fff 0%,
      #6b21ff 50%,
      transparent 80%
    );
    filter: blur(80px);
    opacity: 0.18;
    transform: rotate(7deg);
    pointer-events: none;
    border-radius: 50%;
  }

  .footer-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 60px;
    border-left: 1px dashed var(--border-subtle);
    border-right: 1px dashed var(--border-subtle);
    padding-bottom: 0;
  }

  .footer-nav {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .footer-bio {
    display: flex;
    flex-direction: column;
    gap: 15px;
    flex: 1;
  }

  .footer-bio-text {
    font-family: var(--font-orbitron);
    font-weight: 400;
    font-size: 18px;
    line-height: 1.4;
    letter-spacing: -0.72px;
    color: var(--text-secondary);
  }

  .footer-logo {
    font-family: var(--font-orbitron);
    font-weight: 600;
    font-size: 112px;
    line-height: 1.1;
    letter-spacing: -6.72px;
    color: var(--text-primary);
  }

  .footer-links {
    display: flex;
    gap: 34px;
  }

  .footer-links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer-links a {
    font-family: var(--font-orbitron);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: -0.56px;
    color: var(--text-primary);
    transition: opacity 0.2s;
  }

  .footer-links a:hover {
    opacity: 0.6;
  }

  .footer-bar {
    padding: 20px;
    border-top: 1px solid var(--border-subtle);
  }

  .footer-credit {
    font-family: var(--font-orbitron);
    font-weight: 400;
    font-size: 16px;
    text-align: center;
    letter-spacing: -0.64px;
    color: var(--text-secondary);
  }

  .footer-credit .highlight {
    color: var(--text-primary);
  }

  @media (max-width: 1024px) {
    .footer {
      padding-block: 80px 0;
    }

    .footer-inner {
      gap: 40px;
    }

    .footer-nav {
      flex-direction: column;
      gap: 28px;
    }

    .footer-logo {
      font-size: 84px;
      letter-spacing: -3px;
    }

    .footer-links {
      width: 100%;
      justify-content: space-between;
      gap: 16px;
    }
  }

  @media (max-width: 768px) {
    .footer {
      padding-block: 56px 0;
    }

    .footer-blur {
      width: 520px;
      left: -220px;
      bottom: -140px;
    }

    .footer-inner {
      border-left: 0;
      border-right: 0;
      gap: 32px;
    }

    .footer-bio-text {
      font-size: 15px;
      letter-spacing: 0;
    }

    .footer-logo {
      font-size: 52px;
      letter-spacing: -1.5px;
    }

    .footer-links {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .footer-links ul {
      gap: 12px;
    }

    .footer-links a {
      font-size: 13px;
    }

    .footer-bar {
      padding: 16px 8px;
    }

    .footer-credit {
      font-size: 14px;
      letter-spacing: 0;
      line-height: 1.5;
    }
  }
</style>
