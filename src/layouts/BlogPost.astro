---
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import RelatedPosts from "@/components/blog/RelatedPosts.astro";
import type { CollectionEntry } from "astro:content";
import type { Locale } from "@/i18n/config";
import { withLocale } from "@/i18n/config";

interface Props {
  lang: Locale;
  post: CollectionEntry<"blog">;
  related: CollectionEntry<"blog">[];
  readingTime: number;
}

const { lang, post, related, readingTime } = Astro.props;

const copy = {
  en: {
    back: "Back to blog",
    minRead: "min read",
  },
  es: {
    back: "Volver al blog",
    minRead: "min de lectura",
  },
} as const;

const t = copy[lang];

const formattedDate = new Intl.DateTimeFormat(
  lang === "es" ? "es-AR" : "en-US",
  {
    day: "2-digit",
    month: "long",
    year: "numeric",
  },
).format(post.data.publishDate);
---

<Layout
  lang={lang}
  title={`${post.data.title} | JAI Studio`}
  description={post.data.description}
  image={post.data.image.src}
>
  <main class="blog-post-main container">
    <a class="back-link" href={withLocale(lang, "/blog")}>{t.back}</a>

    <article class="blog-post">
      <header class="post-header" data-reveal="up">
        <p class="eyebrow">{post.data.category ?? "Insights"}</p>
        <h1>{post.data.title}</h1>
        <p class="description">{post.data.description}</p>
        <p class="meta">
          <time>{formattedDate}</time>
          <span>•</span>
          <span>{readingTime} {t.minRead}</span>
        </p>
      </header>

      <Image
        class="hero-image"
        src={post.data.image}
        alt={post.data.imageAlt}
        loading="eager"
        decoding="async"
        widths={[768, 1280]}
        sizes="(max-width: 900px) 100vw, 900px"
        data-reveal="scale"
      />

      <section class="post-content">
        <slot />
      </section>

      <RelatedPosts posts={related} lang={lang} />
    </article>
  </main>
</Layout>

<style>
  .blog-post-main {
    padding-top: 140px;
    padding-bottom: 80px;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-orbitron);
    font-size: 13px;
    letter-spacing: 1px;
    margin-bottom: 22px;
    color: var(--text-secondary);
    text-transform: uppercase;
  }

  .blog-post {
    max-width: 900px;
    margin-inline: auto;
  }

  .post-header {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 28px;
  }

  .eyebrow {
    font-family: var(--font-orbitron);
    font-size: 12px;
    letter-spacing: 1.2px;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  h1 {
    font-family: var(--font-orbitron);
    font-size: clamp(34px, 4vw, 58px);
    line-height: 1.08;
  }

  .description {
    font-family: var(--font-orbitron);
    line-height: 1.7;
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 760px;
  }

  .meta {
    font-family: var(--font-orbitron);
    color: var(--text-muted);
    display: inline-flex;
    gap: 8px;
    font-size: 13px;
    text-transform: uppercase;
  }

  .hero-image {
    width: 100%;
    max-height: 460px;
    object-fit: cover;
    margin-bottom: 36px;
    border: 1px solid var(--border-subtle);
  }

  .post-content {
    font-family: var(--font-orbitron);
    color: var(--text-primary);
    line-height: 1.8;
    font-size: 17px;
  }

  .post-content :global(h2),
  .post-content :global(h3) {
    margin-top: 28px;
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 14px 0;
    padding-left: 22px;
  }

  .post-content :global(p) {
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .blog-post-main {
      padding-top: 108px;
      padding-bottom: 48px;
    }

    .description {
      font-size: 15px;
    }

    .post-content {
      font-size: 15px;
    }
  }
</style>
