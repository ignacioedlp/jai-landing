---
import { Image } from "astro:assets";
import { type Locale, withLocale } from "@/i18n/config";
import heroBg from "@/assets/hero.webp";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const copy = {
  en: {
    title: "Designing and building products that ship.",
    subtitle:
      "We partner with startups and growing teams to craft websites, platforms, and interfaces that feel sharp, fast, and memorable.",
    cta: "START A PROJECT",
  },
  es: {
    title: "Disenamos y construimos productos que salen al mercado.",
    subtitle:
      "Nos asociamos con startups y equipos en crecimiento para crear sitios, plataformas e interfaces rapidas, claras y memorables.",
    cta: "INICIAR PROYECTO",
  },
} as const;

const t = copy[lang];
---

<section class="hero" id="home">
  <div class="hero-bg">
    <Image
      src={heroBg}
      alt=""
      class="hero-img"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      decoding="async"
    />
    <div class="hero-frost"></div>
  </div>

  <div class="hero-content container">
    <div class="hero-text">
      <h1 class="hero-title" data-reveal="up" data-delay="200">
        {t.title}
      </h1>
      <p class="hero-subtitle" data-reveal="up" data-delay="400">
        {t.subtitle}
      </p>
    </div>
    <a
      href={withLocale(lang, "/blog")}
      class="btn hero-cta"
      data-reveal="up"
      data-delay="550"
    >
      <span>{t.cta}</span>
      <span class="btn-icon">
        <svg viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M2 7h10M8 3l4 4-4 4"
            stroke="black"
            stroke-width="1.5"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </span>
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    padding-bottom: 80px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .hero-frost {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 360px;
    background: linear-gradient(
      to bottom,
      rgba(5, 5, 5, 0) 0%,
      rgba(5, 5, 5, 0.9) 60%,
      #050505 100%
    );
    backdrop-filter: blur(4px);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 100%);
  }

  .hero-content {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .hero-title {
    font-family: var(--font-orbitron);
    font-weight: 600;
    font-size: 60px;
    line-height: 1;
    letter-spacing: -2.4px;
    color: var(--text-primary);
    max-width: 608px;
  }

  .hero-subtitle {
    font-family: var(--font-orbitron);
    font-weight: 400;
    font-size: 18px;
    line-height: 1.4;
    letter-spacing: -0.72px;
    color: var(--text-secondary);
    max-width: 580px;
  }

  .hero-cta {
    flex-shrink: 0;
    align-self: flex-end;
  }

  @media (max-width: 1024px) {
    .hero {
      min-height: 85vh;
      padding-bottom: 64px;
    }

    .hero-title {
      font-size: 48px;
      max-width: 560px;
    }

    .hero-subtitle {
      font-size: 16px;
      max-width: 520px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 76vh;
      padding-bottom: 48px;
    }

    .hero-frost {
      height: 280px;
    }

    .hero-content {
      flex-direction: column;
      align-items: flex-start;
      gap: 28px;
    }

    .hero-text {
      gap: 16px;
    }

    .hero-title {
      font-size: 36px;
      letter-spacing: -1.2px;
      max-width: 100%;
      text-wrap: balance;
    }

    .hero-subtitle {
      font-size: 15px;
      line-height: 1.55;
      letter-spacing: 0;
      max-width: 100%;
      text-wrap: pretty;
    }

    .hero-cta {
      align-self: flex-start;
    }
  }

  @media (max-width: 480px) {
    .hero {
      min-height: 70vh;
      padding-bottom: 40px;
    }

    .hero-title {
      font-size: 32px;
      line-height: 1.08;
    }

    .hero-subtitle {
      font-size: 14px;
      line-height: 1.5;
    }
  }
</style>
